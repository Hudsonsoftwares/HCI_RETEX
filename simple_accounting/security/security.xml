<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_simple_accounting" model="ir.module.category">
            <field name="name">Simple Accounting</field>
            <field name="description">Helps you manage your simple accounting.</field>
            <field name="sequence">10</field>
        </record>

        <record id="group_simple_accounting_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="module_category_simple_accounting"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_simple_accounting_manager" model="res.groups">
            <field name="name">Administrator</field>
            <field name="category_id" ref="module_category_simple_accounting"/>
            <field name="implied_ids" eval="[(4, ref('group_simple_accounting_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
