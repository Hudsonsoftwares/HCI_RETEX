<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_send_monthly_accounting_report" model="ir.cron">
            <field name="name">Simple Accounting: Send Monthly Report</field>
            <field name="model_id" ref="model_simple_accounting_transaction"/>
            <field name="state">code</field>
            <field name="code">model._cron_send_monthly_report()</field>
            <field name="user_id" ref="base.user_root"/>
            <!-- Runs on the 1st of every month -->
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
            <!-- Next execution: Start of next month (approx, Odoo handles month boundary if scheduled right). Let's set it to run on the 1st day at 00:01 -->
            <field name="nextcall" eval="(DateTime.now() + relativedelta(months=1, day=1, hour=0, minute=1, second=0)).strftime('%Y-%m-%d %H:%M:%S')" />
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
