<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_smsa_settlement">
        <t t-call="web.html_container">
            <div class="article o_report_no_header" style="margin: 0; padding: 30px; font-family: 'Segoe UI', Arial, sans-serif; font-size: 13px; line-height: 1.5; color: #1a1a1a;">
                
                <!-- Dark Header Block (Matches PnL Report Style) -->
                <div style="background-color: #0b0f19; color: #ffffff; border-radius: 8px; padding: 20px 30px; margin-bottom: 20px;">
                    <!-- Company Names -->
                    <table style="width: 100%; border-collapse: collapse; margin-bottom: 15px; color: #ffffff;">
                        <tr>
                            <td style="width: 50%; text-align: left; vertical-align: middle;">
                                <h2 style="margin: 0; font-size: 20px; font-weight: bold; color: #ffffff;">Retex Cargo Express</h2>
                            </td>
                            <td style="width: 50%; text-align: right; vertical-align: middle;" dir="rtl">
                                <h2 style="margin: 0; font-size: 22px; font-weight: bold; color: #ffffff;">مؤسسة قافلة السرعة للشحن</h2>
                            </td>
                        </tr>
                    </table>
                    
                    <!-- Divider & Tax Info -->
                    <div style="border-top: 1px solid #334155; border-bottom: 1px solid #334155; padding: 8px 0; text-align: center; font-size: 10px; color: #94a3b8; margin-bottom: 15px;">
                        CR: 7026399282 | VAT: 310248611400003
                    </div>
                    
                    <!-- Report Title & Metadata -->
                    <div style="text-align: center;">
                        <h1 style="margin: 0 0 5px 0; font-size: 20px; font-weight: bold; letter-spacing: 1px; color: #ffffff; text-transform: uppercase;">SMSA SETTLEMENT REPORT</h1>
                        <div style="font-size: 11px; color: #94a3b8;">
                            Date: <strong style="color: #ffffff;"><t t-esc="start_date"/></strong> to <strong style="color: #ffffff;"><t t-esc="end_date"/></strong> 
                            | User: <strong style="color: #ffffff;"><t t-esc="current_user"/></strong> 
                            | Generated: <strong style="color: #ffffff;"><t t-esc="print_time"/></strong>
                        </div>
                    </div>
                </div>

                <!-- Financial Summary Grid -->
                <table style="width: 100%; border-collapse: separate; border-spacing: 20px 0; margin-bottom: 30px;">
                    <tr>
                        <!-- SMSA Fees Box -->
                        <td style="width: 33%; background: #fff; border: 1px solid #e2e8f0; border-radius: 6px; padding: 15px; vertical-align: top;">
                            <h4 style="margin: 0 0 10px 0; font-size: 12px; color: #64748b; text-transform: uppercase;">Total SMSA Service Fees</h4>
                            <div style="font-size: 24px; font-weight: bold; color: #dc2626;">
                                <t t-esc="total_service_charges"/> <span style="font-size: 14px; color: #94a3b8;"><t t-esc="currency"/></span>
                            </div>
                            <p style="margin: 5px 0 0 0; font-size: 11px; color: #64748b;">Total cost of all packages</p>
                        </td>

                        <!-- COD Collected Box -->
                        <td style="width: 33%; background: #fff; border: 1px solid #e2e8f0; border-radius: 6px; padding: 15px; vertical-align: top;">
                            <h4 style="margin: 0 0 10px 0; font-size: 12px; color: #64748b; text-transform: uppercase;">Total COD Collected</h4>
                            <div style="font-size: 24px; font-weight: bold; color: #16a34a;">
                                -<t t-esc="total_cod_collected"/> <span style="font-size: 14px; color: #94a3b8;"><t t-esc="currency"/></span>
                            </div>
                            <p style="margin: 5px 0 0 0; font-size: 11px; color: #64748b;">SMSA holds this money</p>
                        </td>

                        <!-- Net Balance Box -->
                        <td style="width: 33%; background: #f8fafc; border: 2px solid #0f172a; border-radius: 6px; padding: 15px; vertical-align: top;">
                            <h4 style="margin: 0 0 10px 0; font-size: 13px; color: #0f172a; text-transform: uppercase; font-weight: bold;">Net Owed to SMSA</h4>
                            <div style="font-size: 28px; font-weight: 900; color: #0f172a;">
                                <t t-esc="net_owed"/> <span style="font-size: 16px; color: #64748b;"><t t-esc="currency"/></span>
                            </div>
                            <p style="margin: 5px 0 0 0; font-size: 11px; color: #64748b; font-style: italic;">
                                <t t-if="net_owed &lt; 0">SMSA owes you this amount.</t>
                                <t t-else="">Amount you must pay SMSA.</t>
                            </p>
                        </td>
                    </tr>
                </table>

                <!-- Breakdown: Cash & Bank Packages -->
                <div style="margin-bottom: 30px;">
                    <h3 style="background: #f1f5f9; padding: 10px; border-left: 4px solid #3b82f6; margin: 0 0 15px 0; font-size: 15px; text-transform: uppercase;">1. Cash &amp; Bank Packages (Service Charges Added to Bill)</h3>
                    <table style="width: 100%; border-collapse: collapse; font-size: 11px;">
                        <thead>
                            <tr style="background-color: #f8fafc; border-bottom: 2px solid #cbd5e1;">
                                <th style="padding: 8px; text-align: left;">Date</th>
                                <th style="padding: 8px; text-align: left;">Inv No</th>
                                <th style="padding: 8px; text-align: left;">Shipper</th>
                                <th style="padding: 8px; text-align: left;">Tracking</th>
                                <th style="padding: 8px; text-align: left;">Method</th>
                                <th style="padding: 8px; text-align: right;">SMSA Cost (Fee)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="cash_bank_txs" t-as="tx">
                                <tr style="border-bottom: 1px solid #e2e8f0;">
                                    <td style="padding: 8px;"><t t-esc="str(tx['date']).split(' ')[0] if tx['date'] else ''"/></td>
                                    <td style="padding: 8px;"><t t-esc="tx['cargo_invoice_id'][1] if tx['cargo_invoice_id'] else ''"/></td>
                                    <td style="padding: 8px;"><t t-esc="tx['shipper_name']"/></td>
                                    <td style="padding: 8px;"><t t-esc="tx['tracking_no']"/></td>
                                    <td style="padding: 8px;">
                                        <span t-att-style="'padding: 3px 6px; border-radius: 4px; font-weight: bold; ' + ('background: #dbeafe; color: #1e40af;' if tx['payment_method'] == 'bank' else 'background: #fef9c3; color: #854d0e;')">
                                            <t t-esc="tx['payment_method'].upper()"/>
                                        </span>
                                    </td>
                                    <td style="padding: 8px; text-align: right; font-weight: bold;"><t t-esc="tx['company_cost']"/></td>
                                </tr>
                            </t>
                            <tr style="background-color: #f8fafc; font-weight: bold; border-bottom: 2px solid #0f172a;">
                                <td colspan="5" style="padding: 8px; text-align: right;">Total Cash/Bank Fees:</td>
                                <td style="padding: 8px; text-align: right; color: #dc2626;"><t t-esc="total_cash_bank_fees"/></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- Breakdown: COD Packages -->
                <div style="margin-bottom: 30px;">
                    <h3 style="background: #f1f5f9; padding: 10px; border-left: 4px solid #ef4444; margin: 0 0 15px 0; font-size: 15px; text-transform: uppercase;">2. COD Packages (Total Collected Reduces Bill)</h3>
                    <table style="width: 100%; border-collapse: collapse; font-size: 11px;">
                        <thead>
                            <tr style="background-color: #f8fafc; border-bottom: 2px solid #cbd5e1;">
                                <th style="padding: 8px; text-align: left;">Date</th>
                                <th style="padding: 8px; text-align: left;">Inv No</th>
                                <th style="padding: 8px; text-align: left;">Shipper</th>
                                <th style="padding: 8px; text-align: right;">SMSA Cost (Fee)</th>
                                <th style="padding: 8px; text-align: right; color: #16a34a;">Total Collected (Reduces Bill)</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="cod_txs" t-as="tx">
                                <tr style="border-bottom: 1px solid #e2e8f0;">
                                    <td style="padding: 8px;"><t t-esc="str(tx['date']).split(' ')[0] if tx['date'] else ''"/></td>
                                    <td style="padding: 8px;"><t t-esc="tx['cargo_invoice_id'][1] if tx['cargo_invoice_id'] else ''"/></td>
                                    <td style="padding: 8px;"><t t-esc="tx['shipper_name']"/></td>
                                    <td style="padding: 8px; text-align: right;"><t t-esc="tx['company_cost']"/></td>
                                    <td style="padding: 8px; text-align: right; font-weight: bold; color: #16a34a;">-<t t-esc="tx['amount']"/></td>
                                </tr>
                            </t>
                            <tr style="background-color: #f8fafc; font-weight: bold; border-bottom: 2px solid #0f172a;">
                                <td colspan="3" style="padding: 8px; text-align: right;">Totals:</td>
                                <td style="padding: 8px; text-align: right;"><t t-esc="total_cod_fees"/></td>
                                <td style="padding: 8px; text-align: right; color: #16a34a;">-<t t-esc="total_cod_collected"/></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

            </div>
        </t>
    </template>
</odoo>
