<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="paperformat_simple_accounting_ledger" model="report.paperformat">
        <field name="name">Accounting Ledger A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">10</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_simple_accounting_ledger" model="ir.actions.report">
        <field name="name">Accounting Ledger</field>
        <field name="model">simple.accounting.report.wizard</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">simple_accounting.report_simple_accounting_ledger</field>
        <field name="report_file">simple_accounting.report_simple_accounting_ledger</field>
        <field name="print_report_name">'Ledger_%s_to_%s' % (object.start_date, object.end_date)</field>
        <field name="binding_model_id" ref="model_simple_accounting_report_wizard"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_simple_accounting_ledger"/>
    </record>
</odoo>
