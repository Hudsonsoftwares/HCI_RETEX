<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_simple_accounting_category_tree" model="ir.ui.view">
        <field name="name">simple.accounting.category.tree</field>
        <field name="model">simple.accounting.category</field>
        <field name="arch" type="xml">
            <list string="Categories" editable="bottom">
                <field name="name"/>
                <field name="type"/>
            </list>
        </field>
    </record>

    <record id="action_simple_accounting_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">simple.accounting.category</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_simple_accounting_categories"
              name="Categories"
              parent="menu_simple_accounting_configuration"
              action="action_simple_accounting_category"
              sequence="10"/>
</odoo>
