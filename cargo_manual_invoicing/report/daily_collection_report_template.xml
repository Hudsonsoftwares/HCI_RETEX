<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="report_daily_collection_document">
        <t t-call="web.html_container">
            <div class="article o_report_no_header" style="margin: 0; padding: 30px; font-family: 'Segoe UI', Arial, sans-serif; font-size: 12px; line-height: 1.5; color: #1a1a1a;">
                    <style>
                        .dcr-header {
                            background: #000;
                            color: #fff;
                            border-radius: 8px;
                            margin-bottom: 20px;
                            padding: 15px 20px;
                        }
                        .dcr-header-table {
                            width: 100%;
                            color: #fff;
                            margin-bottom: 15px;
                        }
                        .dcr-header-table td {
                            vertical-align: middle;
                        }
                        .dcr-header-meta {
                            text-align: center;
                            font-size: 11px;
                            color: #ccc;
                            border-top: 1px solid #333;
                            border-bottom: 1px solid #333;
                            padding: 8px 0;
                            margin-bottom: 15px;
                        }
                        .dcr-header-report-name {
                            text-align: center;
                        }
                        .dcr-header-report-name h3 {
                            margin: 0 0 5px 0;
                            font-size: 16px;
                            letter-spacing: 1px;
                            font-weight: bold;
                        }
                        .dcr-header-report-name p {
                            margin: 0;
                            font-size: 11px;
                            color: #ddd;
                        }
                        .dcr-section-title {
                            background: #f1f5f9;
                            border-left: 4px solid #000;
                            color: #0f172a;
                            padding: 10px 15px;
                            font-weight: 800;
                            font-size: 14px;
                            margin-top: 30px;
                            margin-bottom: 15px;
                            text-transform: uppercase;
                            letter-spacing: 0.5px;
                        }
                        .dcr-table {
                            width: 100%;
                            border-collapse: collapse;
                            margin-bottom: 25px;
                            font-size: 12px;
                        }
                        .dcr-table th {
                            background: #f8f9fa;
                            border-bottom: 2px solid #000;
                            border-top: 1px solid #dee2e6;
                            padding: 10px 12px;
                            font-weight: bold;
                            color: #1e293b;
                            text-align: left;
                            text-transform: uppercase;
                        }
                        .dcr-table td {
                            border-bottom: 1px solid #e2e8f0;
                            padding: 10px 12px;
                            color: #334155;
                        }
                        .dcr-table tr:nth-child(even) td {
                            background: #f8fafc;
                        }
                        .dcr-table .number {
                            text-align: right;
                            font-family: monospace;
                            font-size: 12px;
                        }
                        .dcr-total-row th, .dcr-total-row td {
                            background: #0f172a !important;
                            color: #fff !important;
                            font-weight: bold;
                            font-size: 13px;
                            border-top: 2px solid #000;
                        }
                        .dcr-footer {
                            margin-top: 40px;
                            padding-top: 15px;
                            border-top: 2px solid #000;
                            font-size: 9px;
                            color: #64748b;
                            text-align: center;
                        }
                        .badge {
                            padding: 3px 6px;
                            border-radius: 4px;
                            font-size: 10px;
                            font-weight: bold;
                        }
                        .badge-gray { background: #e2e8f0; color: #0f172a; }
                        .text-cash { color: #16a34a; font-weight: bold; }
                        .text-card { color: #2563eb; font-weight: bold; }
                        .text-company { color: #9333ea; font-weight: bold; }
                    </style>

                    <!-- Header -->
                    <div class="dcr-header">
                        <table class="dcr-header-table">
                            <tr>
                                <td style="text-align: left; width: 45%;">
                                    <h2 style="margin: 0; font-size: 16px; font-weight: 800;">Retex Cargo Express</h2>
                                </td>
                                <td style="text-align: center; width: 10%;">
                                    <span style="font-size: 24px;">✈️</span>
                                </td>
                                <td style="text-align: right; width: 45%; direction: rtl;">
                                    <h2 style="margin: 0; font-size: 20px; font-weight: bold;">مؤسسة قافلة السرعة للشحن</h2>
                                </td>
                            </tr>
                        </table>
                        <div class="dcr-header-meta">
                            CR: 7026399282 &amp;nbsp;|&amp;nbsp; VAT: 310248611400003
                        </div>
                        <div class="dcr-header-report-name">
                            <h3>DAILY COLLECTION REPORT | تقرير التحصيل اليومي</h3>
                            <p>
                                Date: <strong><t t-esc="data.get('date_from')"/></strong> to <strong><t t-esc="data.get('date_to')"/></strong> &amp;nbsp;|&amp;nbsp; 
                                User: <strong><t t-esc="data.get('generated_by')"/></strong> &amp;nbsp;|&amp;nbsp; 
                                Generated: <strong><t t-esc="data.get('generated_at')"/></strong>
                            </p>
                        </div>
                    </div>

                    <div style="width: 100%; margin-bottom: 25px;">
                        <!-- Overall Summary -->
                        <div>
                            <div class="dcr-section-title">Overall Summary</div>
                            <table class="dcr-table">
                                <tr>
                                    <td>Total Invoices</td>
                                    <td class="number"><t t-esc="data.get('total_invoices')"/></td>
                                </tr>
                                <tr>
                                    <td>Total Net Amount</td>
                                    <td class="number"><t t-esc="'%.2f' % data.get('total_net', 0.0)"/></td>
                                </tr>
                                <tr>
                                    <td>Total VAT (15%)</td>
                                    <td class="number"><t t-esc="'%.2f' % data.get('total_vat', 0.0)"/></td>
                                </tr>
                                <tr>
                                    <td>Total Extra Charges</td>
                                    <td class="number"><t t-esc="'%.2f' % data.get('total_extra', 0.0)"/></td>
                                </tr>
                                <tr class="dcr-total-row">
                                    <td>GRAND TOTAL (SAR)</td>
                                    <td class="number"><t t-esc="'%.2f' % data.get('total_gross', 0.0)"/></td>
                                </tr>
                            </table>
                        </div>

                        <!-- Collection by Shipment Type -->
                        <div style="margin-top: 30px;">
                            <div class="dcr-section-title">By Shipment Type</div>
                            <table class="dcr-table">
                                <tr>
                                    <th>Shipment Type</th>
                                    <th class="number">Count</th>
                                    <th class="number">Total (SAR)</th>
                                </tr>
                                <t t-foreach="data.get('shipment_types', [])" t-as="st">
                                    <tr>
                                        <td>
                                            <t t-if="st['shipment_type'] == 'domestic'">🏠 Domestic</t>
                                            <t t-elif="st['shipment_type'] == 'international'">🌍 International</t>
                                            <t t-else=""><t t-esc="st['shipment_type'] or 'Unknown'"/></t>
                                        </td>
                                        <td class="number"><t t-esc="st['count']"/></td>
                                        <td class="number"><t t-esc="'%.2f' % st['gross_total']"/></td>
                                    </tr>
                                </t>
                                <tr class="dcr-total-row">
                                    <td>TOTAL</td>
                                    <td class="number"><t t-esc="data.get('total_invoices')"/></td>
                                    <td class="number"><t t-esc="'%.2f' % data.get('total_gross', 0.0)"/></td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <!-- Collection by Payment Mode -->
                    <div class="dcr-section-title">Collection by Payment Mode</div>
                    <table class="dcr-table">
                        <tr>
                            <th>Payment Mode</th>
                            <th class="number">Count</th>
                            <th class="number">Total (SAR)</th>
                            <th class="number">% Share</th>
                        </tr>
                        <t t-foreach="data.get('paymode_data', [])" t-as="pm">
                            <tr>
                                <td>
                                    <t t-if="pm['paymode'] == 'cash'">💵 <t t-esc="pm['label']"/></t>
                                    <t t-elif="pm['paymode'] == 'card'">💳 <t t-esc="pm['label']"/></t>
                                    <t t-elif="pm['paymode'] == 'company'">🏢 <t t-esc="pm['label']"/></t>
                                    <t t-else=""><t t-esc="pm['label']"/></t>
                                </td>
                                <td class="number"><t t-esc="pm['count']"/></td>
                                <td class="number"><t t-esc="'%.2f' % pm['total']"/></td>
                                <td class="number"><t t-esc="'%.1f' % pm['pct']"/>%</td>
                            </tr>
                        </t>
                        <tr class="dcr-total-row">
                            <td>TOTAL</td>
                            <td class="number"><t t-esc="data.get('total_invoices')"/></td>
                            <td class="number"><t t-esc="'%.2f' % data.get('total_gross', 0.0)"/></td>
                            <td class="number">100.0%</td>
                        </tr>
                    </table>

                    <!-- User-wise Breakdown -->
                    <div class="dcr-section-title">User-wise Breakdown</div>
                    <table class="dcr-table">
                        <tr>
                            <th>User Name</th>
                            <th class="number">Invoices</th>
                            <th class="number">Cash</th>
                            <th class="number">Card</th>
                            <th class="number">Company</th>
                            <th class="number">Total (SAR)</th>
                        </tr>
                        <t t-foreach="data.get('agent_summary', [])" t-as="ag">
                            <tr>
                                <td><t t-esc="ag['agent_name']"/></td>
                                <td class="number"><t t-esc="ag['total_invoices']"/></td>
                                <td class="number"><t t-esc="'%.2f' % ag['cash_total']"/></td>
                                <td class="number"><t t-esc="'%.2f' % ag['card_total']"/></td>
                                <td class="number"><t t-esc="'%.2f' % ag['company_total']"/></td>
                                <td class="number" style="font-weight: bold;"><t t-esc="'%.2f' % ag['gross_total']"/></td>
                            </tr>
                        </t>
                        <t t-if="not data.get('agent_summary')">
                            <tr>
                                <td colspan="6" class="text-center">No data available for this period.</td>
                            </tr>
                        </t>
                        <t t-else="">
                            <tr class="dcr-total-row">
                                <td>TOTAL</td>
                                <td class="number"><t t-esc="data.get('total_invoices')"/></td>
                                <td class="number"><t t-esc="'%.2f' % sum(a['cash_total'] for a in data['agent_summary'])"/></td>
                                <td class="number"><t t-esc="'%.2f' % sum(a['card_total'] for a in data['agent_summary'])"/></td>
                                <td class="number"><t t-esc="'%.2f' % sum(a['company_total'] for a in data['agent_summary'])"/></td>
                                <td class="number"><t t-esc="'%.2f' % data.get('total_gross', 0.0)"/></td>
                            </tr>
                        </t>
                    </table>

                    <!-- Detailed Report (If requested) -->
                    <t t-if="data.get('report_type') == 'detailed'">
                        <div style="page-break-before: always;"/>
                        <div class="dcr-section-title">Detailed Invoice Breakdown</div>
                        <table class="dcr-table">
                            <thead>
                                <tr>
                                    <th style="width: 15%;">Invoice #</th>
                                    <th style="width: 15%;">Date/Time</th>
                                    <th style="width: 12%;">User</th>
                                    <th style="width: 18%;">Shipper</th>
                                    <th style="width: 10%;">Dest.</th>
                                    <th style="width: 10%;">Pay Mode</th>
                                    <th style="width: 10%;">Carrier</th>
                                    <th class="number" style="width: 10%;">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="data.get('invoice_lines', [])" t-as="inv">
                                    <tr>
                                        <td style="font-weight: bold; color: #0f172a;"><t t-esc="inv['invoice_number']"/></td>
                                        <td style="color: #64748b;"><t t-esc="inv['shipping_date']"/></td>
                                        <td><span class="badge badge-gray"><t t-esc="inv['agent_name']"/></span></td>
                                        <td><t t-esc="inv['shipper_name']"/></td>
                                        <td><t t-esc="inv['destination']"/></td>
                                        <td>
                                            <t t-if="inv['paymode'] == 'cash'"><span class="text-cash">Cash</span></t>
                                            <t t-elif="inv['paymode'] == 'card'"><span class="text-card">Card</span></t>
                                            <t t-elif="inv['paymode'] == 'company'"><span class="text-company">Company</span></t>
                                            <t t-else=""><t t-esc="inv['paymode']"/></t>
                                        </td>
                                        <td><t t-esc="inv['carrier']"/></td>
                                        <td class="number" style="font-weight: bold; color: #0f172a;"><t t-esc="'%.2f' % inv['gross_total']"/></td>
                                    </tr>
                                </t>
                                <t t-if="not data.get('invoice_lines')">
                                    <tr>
                                        <td colspan="8" class="text-center" style="padding: 20px; color: #94a3b8; font-style: italic;">No invoices found for this period.</td>
                                    </tr>
                                </t>
                                <t t-else="">
                                    <tr class="dcr-total-row">
                                        <td colspan="7" style="text-align: right; padding-right: 15px;">GRAND TOTAL</td>
                                        <td class="number"><t t-esc="'%.2f' % data.get('total_gross', 0.0)"/></td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>

                    <!-- Footer -->
                    <div class="dcr-footer">
                        Report generated on: <t t-esc="data.get('generated_at')"/> | Generated by: <t t-esc="data.get('generated_by')"/><br/>
                        Retex Cargo Express | Riyadh, Saudi Arabia
                    </div>
                </div>
        </t>
    </template>
</odoo>
