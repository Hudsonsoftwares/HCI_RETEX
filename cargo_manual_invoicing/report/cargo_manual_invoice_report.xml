<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Paper format MUST be before the report that references it -->
    <record id="paperformat_cargo_invoice" model="report.paperformat">
        <field name="name">Cargo Invoice A4</field>
        <field name="default" eval="False"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">5</field>
        <field name="margin_bottom">5</field>
        <field name="margin_left">5</field>
        <field name="margin_right">5</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_cargo_invoice" model="ir.actions.report">
        <field name="name">Cargo Invoice</field>
        <field name="model">cargo.manual.invoice</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">cargo_manual_invoicing.report_cargo_invoice_document</field>
        <field name="report_file">cargo_manual_invoicing.report_cargo_invoice_document</field>
        <field name="binding_model_id" ref="model_cargo_manual_invoice"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_cargo_invoice"/>
    </record>
</odoo>