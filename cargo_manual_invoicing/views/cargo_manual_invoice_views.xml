<?xml version="1.0" encoding="utf-8"?>
<odoo>





    <!-- ═══ Inherited Partner Form to Simplify it for Cargo ═══ -->
    <record id="view_partner_form_cargo_inherit" model="ir.ui.view">
        <field name="name">res.partner.form.cargo.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Hide tabs if cargo_simplified_form context is passed -->
            <xpath expr="//page[@name='sales_purchases']" position="attributes">
                <attribute name="invisible">context.get('cargo_simplified_form')</attribute>
            </xpath>
            <xpath expr="//page[@name='internal_notes']" position="attributes">
                <attribute name="invisible">context.get('cargo_simplified_form')</attribute>
            </xpath>
        </field>
    </record>

    <!-- ═══ Simplified Partner Form for Popup ═══ -->
    <record id="simplified_partner_form" model="ir.ui.view">
        <field name="name">simplified.partner.form</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <form string="Contact Info">
                <sheet>
                    <group>
                        <group>
                            <field name="name" string="Name" required="1"/>
                            <field name="mobile" string="Mobile" widget="phone"/>
                            <field name="phone" string="Tel" widget="phone"/>
                            <field name="email" string="Email" widget="email"/>
                        </group>
                        <group>
                            <field name="vat"/>
                            <field name="company_name" string="Company Name"/>
                        </group>
                    </group>
                    <group string="Address">
                        <label for="street" string="Address"/>
                        <div class="o_address_format">
                            <field name="street" placeholder="Street..." class="o_address_street"/>
                            <field name="street2" placeholder="Street 2..." class="o_address_street"/>
                            <field name="city" placeholder="City" class="o_address_city"/>
                            <field name="state_id" class="o_address_state" placeholder="State" options="{'no_open': True, 'no_quick_create': True}"/>
                            <field name="zip" placeholder="ZIP" class="o_address_zip"/>
                            <field name="country_id" placeholder="Country" class="o_address_country" options="{'no_open': True, 'no_create': True}"/>
                        </div>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══ List View ═══ -->
    <record id="cargo_manual_invoice_list" model="ir.ui.view">
        <field name="name">cargo.manual.invoice.list</field>
        <field name="model">cargo.manual.invoice</field>
        <field name="arch" type="xml">
            <list string="Cargo Invoices" sample="1" expand="1"
                  decoration-info="shipment_type == 'domestic'"
                  decoration-primary="shipment_type == 'international'">
                <field name="invoice_number" string="Invoice #" decoration-bf="1"/>
                <field name="shipping_date" widget="date"/>
                <field name="shipment_type" widget="badge"
                       decoration-info="shipment_type == 'domestic'"
                       decoration-primary="shipment_type == 'international'"/>
                <field name="destination_country_id"/>
                <field name="shipper_name" optional="show"/>
                <field name="receiver_name" optional="show"/>
                <field name="carrier" optional="show"/>
                <field name="paymode" widget="badge"
                       decoration-success="paymode == 'cash'"
                       decoration-info="paymode == 'card'"
                       decoration-warning="paymode == 'company'"/>
                <field name="status" widget="badge"
                       decoration-success="status == 'DELIVERED'"
                       decoration-info="status != 'DELIVERED'"/>
                <field name="delivery_partner" optional="show"/>
                <field name="email_sent" widget="boolean" string="Emailed"/>
                <field name="gross_total" sum="Total" decoration-bf="1"/>
            </list>
        </field>
    </record>

    <!-- ═══ Form View ═══ -->
    <record id="cargo_manual_invoice_form" model="ir.ui.view">
        <field name="name">cargo.manual.invoice.form</field>
        <field name="model">cargo.manual.invoice</field>
        <field name="arch" type="xml">
            <form string="Cargo Invoice">
                <header>
                    <button name="action_print_invoice"
                            string="Print Invoice"
                            type="object"
                            class="btn-primary"
                            icon="fa-print"/>
                    <button name="action_send_email"
                            string="Send Email"
                            type="object"
                            class="btn-success"
                            icon="fa-envelope"/>
                    <button name="action_send_whatsapp"
                            string="Send via WhatsApp"
                            type="object"
                            class="btn-success"
                            icon="fa-whatsapp"/>

                    <field name="email_sent" widget="boolean_toggle" readonly="1"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="International" bg_color="bg-primary" invisible="shipment_type != 'international'"/>
                    <widget name="web_ribbon" title="Domestic" bg_color="bg-info" invisible="shipment_type != 'domestic'"/>

                    <div class="oe_title mb-3">
                        <label for="invoice_number" string="Invoice Number"/>
                        <h1>
                            <field name="invoice_number" readonly="1"
                                   placeholder="Auto-generated on save"/>
                        </h1>
                    </div>

                    <group>
                        <group string="SHIPMENT INFO">
                            <field name="shipping_date" string="SHIPPING DATE"/>
                            <field name="shipment_type" widget="radio"
                                   options="{'horizontal': true}" string="SHIPMENT TYPE"/>
                            <field name="status" string="STATUS"/>
                            <field name="manual_status" string="SPECIFY STATUS" invisible="status != 'manual'"/>
                        </group>
                        <group string="USER / PAYMENT">
                            <field name="agent_name" string="USER NAME"/>
                            <field name="paymode" widget="radio"
                                   options="{'horizontal': true}" string="PAYMENT MODE"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="PARTIES INFO" name="parties_info">
                            <group>
                                <group string="SHIPPER INFO — معلومات الشاحن">
                                    <field name="shipper_id" string="SHIPPER NAME" placeholder="Type name to search or create..." context="{'form_view_ref': 'cargo_manual_invoicing.simplified_partner_form'}"/>
                                    <field name="origin" string="ORIGIN" placeholder="e.g. Saudi Arabia Riyadh"/>
                                    <field name="shipper_name" invisible="1"/>
                                    <field name="shipper_mobile" string="MOBILE" widget="phone" placeholder="e.g. 0599649593"/>
                                    <field name="shipper_tel" string="TEL" widget="phone" placeholder="Optional landline"/>
                                    <field name="shipper_vat_no" string="VAT NO" placeholder="Customer VAT Number"/>
                                    <field name="shipper_company" string="COMPANY" placeholder="Company name"/>
                                    <field name="shipper_email" string="EMAIL" widget="email" placeholder="email@example.com"/>
                                    <field name="shipper_address" string="ADDRESS" placeholder="Full address"/>
                                </group>
                                <group string="RECEIVER INFO — معلومات استقبال">
                                    <field name="receiver_id" string="RECEIVER NAME" placeholder="Type name to search or create..." context="{'form_view_ref': 'cargo_manual_invoicing.simplified_partner_form'}"/>
                                    <field name="destination" invisible="1"/>
                                    <field name="destination_country_id" string="COUNTRY" placeholder="e.g. India" options="{'no_create': True, 'no_open': True}"/>
                                    <field name="receiver_name" invisible="1"/>
                                    <field name="receiver_mobile" string="MOBILE" widget="phone" placeholder="e.g. 97430320008"/>
                                    <field name="receiver_tel" string="TEL" widget="phone" placeholder="Optional landline"/>
                                    <field name="receiver_company" string="COMPANY" placeholder="Company name"/>
                                    <field name="receiver_email" string="EMAIL" widget="email" placeholder="email@example.com"/>
                                    <field name="receiver_address" string="ADDRESS" placeholder="Full address"/>
                                </group>
                            </group>
                        </page>
                        <page string="CARGO &amp; FINANCIALS" name="cargo_financials">
                            <group>
                                <group string="CARGO DETAILS — معلومات الشحن">
                                    <field name="weight" string="WEIGHT (KG)" placeholder="0.00"/>
                                    <field name="pieces" string="PIECES" placeholder="1"/>
                                    <field name="delivery_partner" string="DELIVERY PARTNER"/>
                                    <field name="manual_delivery_partner" string="SPECIFY PARTNER" invisible="delivery_partner != 'manual'"/>
                                    <field name="carrier" invisible="1"/>
                                    <field name="airway_bill" string="AIRWAY BILL" placeholder="Tracking number"/>
                                    <field name="product_info" string="PRODUCT INFO" placeholder="Describe the cargo contents"/>
                                    <field name="special_info" string="SPECIAL INFO" placeholder="Any special instructions"/>
                                </group>
                                <group string="INVOICE DETAILS — تفاصيل الفاتورة" class="oe_subtotal_footer oe_right">
                                    <field name="net_amount" string="NET AMOUNT (SAR)"/>
                                    <field name="vat_amount" string="VAT 15%"/>
                                    <field name="extra_charge" string="EXTRA CHARGE"/>
                                    <field name="gross_total" string="GROSS TOTAL (SAR)" class="oe_subtotal_footer_separator"/>
                                </group>
                            </group>
                        </page>

                        <page string="ZATCA QR Code" name="zatca_qr">
                            <group>
                                <group>
                                    <field name="zatca_qr_image" widget="image" readonly="1" nolabel="1" options="{'size': [200, 200]}"/>
                                </group>
                                <group>
                                    <div class="alert alert-info" role="alert">
                                        <h4 class="alert-heading">ZATCA Phase 1 Compliant QR Code</h4>
                                        <p>This QR code automatically encodes the following required fields in TLV Base64 format:</p>
                                        <ol>
                                            <li><strong>Seller Name:</strong> Retex Cargo Express</li>
                                            <li><strong>VAT Number:</strong> 310248611400003</li>
                                            <li><strong>Time Stamp:</strong> Date &amp; Time of Invoice</li>
                                            <li><strong>Invoice Total:</strong> Gross Total Amount</li>
                                            <li><strong>VAT Total:</strong> VAT Amount (15%)</li>
                                        </ol>
                                    </div>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ═══ Graph View ═══ -->
    <record id="cargo_manual_invoice_graph" model="ir.ui.view">
        <field name="name">cargo.manual.invoice.graph</field>
        <field name="model">cargo.manual.invoice</field>
        <field name="arch" type="xml">
            <graph string="Invoice Analysis" type="bar" sample="1">
                <field name="shipping_date" interval="month"/>
                <field name="gross_total" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ═══ Pivot View ═══ -->
    <record id="cargo_manual_invoice_pivot" model="ir.ui.view">
        <field name="name">cargo.manual.invoice.pivot</field>
        <field name="model">cargo.manual.invoice</field>
        <field name="arch" type="xml">
            <pivot string="Invoice Analysis" sample="1">
                <field name="shipping_date" interval="month" type="row"/>
                <field name="shipment_type" type="col"/>
                <field name="gross_total" type="measure"/>
                <field name="net_amount" type="measure"/>
                <field name="vat_amount" type="measure"/>
                <field name="extra_charge" type="measure"/>
                <field name="weight" type="measure"/>
                <field name="pieces" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- ═══ Search View ═══ -->
    <record id="cargo_manual_invoice_search" model="ir.ui.view">
        <field name="name">cargo.manual.invoice.search</field>
        <field name="model">cargo.manual.invoice</field>
        <field name="arch" type="xml">
            <search string="Search Invoices">
                <field name="invoice_number" string="Invoice #"/>
                <field name="shipper_name"/>
                <field name="receiver_name"/>
                <field name="carrier"/>
                <field name="airway_bill"/>
                <field name="destination"/>
                <separator/>
                <filter name="domestic" string="Domestic"
                        domain="[('shipment_type','=','domestic')]"/>
                <filter name="international" string="International"
                        domain="[('shipment_type','=','international')]"/>
                <separator/>
                <filter name="today" string="Today"
                        domain="[('shipping_date','&gt;=', (context_today()).strftime('%%Y-%%m-%%d')),
                                 ('shipping_date','&lt;', (context_today() + datetime.timedelta(days=1)).strftime('%%Y-%%m-%%d'))]"/>
                <filter name="this_month" string="This Month"
                        domain="[('shipping_date','&gt;=', (context_today()).strftime('%%Y-%%m-01'))]"/>
                <filter name="this_year" string="This Year"
                        domain="[('shipping_date','&gt;=', (context_today()).strftime('%%Y-01-01'))]"/>
                <separator/>
                <filter name="emailed" string="Emailed"
                        domain="[('email_sent','=',True)]"/>
                <filter name="not_emailed" string="Not Emailed"
                        domain="[('email_sent','=',False)]"/>

                <group expand="0" string="Group By">
                    <filter name="group_shipment_type" string="Shipment Type"
                            context="{'group_by': 'shipment_type'}"/>
                    <filter name="group_carrier" string="Carrier"
                            context="{'group_by': 'carrier'}"/>
                    <filter name="group_status" string="Status"
                            context="{'group_by': 'status'}"/>

                    <filter name="group_paymode" string="Payment Mode"
                            context="{'group_by': 'paymode'}"/>
                    <filter name="group_day" string="Day"
                            context="{'group_by': 'shipping_date:day'}"/>
                    <filter name="group_month" string="Month"
                            context="{'group_by': 'shipping_date:month'}"/>
                    <filter name="group_year" string="Year"
                            context="{'group_by': 'shipping_date:year'}"/>
                    <filter name="group_agent" string="User"
                            context="{'group_by': 'agent_name'}"/>
                </group>
                <searchpanel>
                    <field name="shipment_type" enable_counters="1" icon="fa-globe" select="multi"/>
                    <field name="paymode" enable_counters="1" icon="fa-credit-card" select="multi"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <!-- ═══ Main Action (List + Form + Graph + Pivot) ═══ -->
    <record id="action_cargo_manual_invoice" model="ir.actions.act_window">
        <field name="name">Cargo Invoices</field>
        <field name="res_model">cargo.manual.invoice</field>
        <field name="view_mode">list,form,graph,pivot</field>
        <field name="search_view_id" ref="cargo_manual_invoice_search"/>
        <field name="context">{'search_default_group_day': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first Cargo Invoice!
            </p>
            <p>Click the <b>New</b> button to start entering shipment details.</p>
        </field>
    </record>

</odoo>