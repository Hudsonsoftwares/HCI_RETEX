<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_license_status_check" model="ir.cron">
            <field name="name">License: Daily Status Check</field>
            <field name="model_id" ref="model_license_management"/>
            <field name="state">code</field>
            <field name="code">model._cron_check_license_status()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>
