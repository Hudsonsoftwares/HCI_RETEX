<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="email_template_license_status" model="mail.template">
            <field name="name">License Status Notification</field>
            <field name="model_id" ref="model_license_management"/>
            <field name="subject">License Update: {{ object.license_status.upper() }} - {{ object.company_name }}</field>
            <field name="email_to">{{ object.customer_email }}</field>
            <field name="body_html" type="html">
<div style="margin: 0px; padding: 0px;">
    <p style="margin: 0px; padding: 0px; font-size: 13px;">
        Hello <t t-out="object.customer_name or ''"/>,<br/><br/>
        This is an automated notification regarding your software license.<br/>
        
        <strong>License Status:</strong> <t t-out="object.license_status or ''"/><br/>
        <strong>Expiry Date:</strong> <t t-out="object.expiry_date or ''"/><br/>
        <strong>Days Remaining:</strong> <t t-out="object.days_remaining or ''"/><br/>
        <br/>
        Please contact support to renew your license.<br/>
        <br/>
        Thank you!
    </p>
</div>
            </field>
        </record>
    </data>
</odoo>
