<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- License Management Category -->
        <record id="module_category_license_management" model="ir.module.category">
            <field name="name">License Management</field>
            <field name="description">Manage software licenses</field>
            <field name="sequence">20</field>
        </record>

        <!-- Readonly Group -->
        <record id="group_license_readonly" model="res.groups">
            <field name="name">Read-Only</field>
            <field name="category_id" ref="module_category_license_management"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Admin Group -->
        <record id="group_license_admin" model="res.groups">
            <field name="name">Administrator</field>
            <field name="category_id" ref="module_category_license_management"/>
            <field name="implied_ids" eval="[(4, ref('group_license_readonly'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <!-- Record Rules -->
        <record id="rule_license_management_readonly" model="ir.rule">
            <field name="name">License Management Readonly for Users</field>
            <field name="model_id" ref="model_license_management"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('base.group_user'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>
        
        <record id="rule_license_management_admin" model="ir.rule">
            <field name="name">License Management Admin All</field>
            <field name="model_id" ref="model_license_management"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('group_license_admin'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>
    </data>
</odoo>
