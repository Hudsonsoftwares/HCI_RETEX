<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="license_expired_page" name="License Expired">
        <t t-call="web.layout">
            <t t-set="head">
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet"/>
                <style>
                    body {
                        background-color: #f5f5f5;
                        display: flex;
                        align-items: center;
                        justify-content: center;
                        min-height: 100vh;
                        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
                    }
                    .license-card {
                        background: white;
                        border-radius: 12px;
                        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
                        padding: 40px;
                        max-width: 600px;
                        width: 100%;
                        text-align: center;
                    }
                    .icon-container {
                        font-size: 64px;
                        color: #dc3545;
                        margin-bottom: 20px;
                    }
                    .info-table {
                        width: 100%;
                        text-align: left;
                        margin-top: 30px;
                        margin-bottom: 30px;
                        border: 1px solid #eee;
                        border-radius: 8px;
                        overflow: hidden;
                    }
                    .info-table th, .info-table td {
                        padding: 12px 15px;
                        border-bottom: 1px solid #eee;
                    }
                    .info-table th {
                        background-color: #fafafa;
                        font-weight: 600;
                        color: #555;
                        width: 40%;
                    }
                    .info-table tr:last-child th, .info-table tr:last-child td {
                        border-bottom: none;
                    }
                    .status-badge {
                        background-color: #dc3545;
                        color: white;
                        padding: 5px 10px;
                        border-radius: 4px;
                        font-size: 14px;
                        font-weight: bold;
                    }
                    .footer-text {
                        margin-top: 40px;
                        font-size: 12px;
                        color: #aaa;
                    }
                </style>
            </t>
            

            <div class="license-card">
                <div class="icon-container">
                    <i class="fa fa-lock"></i>
                </div>
                <h1 style="font-weight: bold; color: #333;">License Expired</h1>
                <p style="color: #666; font-size: 16px;">Your software subscription has expired and access has been restricted.</p>
                
                <table class="info-table">
                    <tr>
                        <th>Database Name</th>
                        <td><t t-out="db_name"/></td>
                    </tr>
                    <tr>
                        <th>License Key</th>
                        <td><t t-out="masked_key"/></td>
                    </tr>
                    <tr>
                        <th>Expiry Date</th>
                        <td><t t-out="expiry_date"/></td>
                    </tr>
                    <tr>
                        <th>Current Status</th>
                        <td><span class="status-badge"><t t-out="status"/></span></td>
                    </tr>
                </table>
                
                <div style="margin-bottom: 30px; background: #f8f9fa; padding: 20px; border-radius: 8px;">
                    <h5 style="margin-bottom: 15px; color: #333;">Contact Support to Renew</h5>
                    <p style="margin-bottom: 5px; color: #555;"><strong><t t-out="vendor_name"/></strong></p>
                    <p style="margin-bottom: 5px;"><a t-attf-href="mailto:{{vendor_email}}" style="color: #0d6efd; text-decoration: none;"><t t-out="vendor_email"/></a></p>
                    <t t-if="vendor_phone">
                        <p style="margin-bottom: 0;"><a t-attf-href="tel:{{vendor_phone}}" style="color: #0d6efd; text-decoration: none;"><t t-out="vendor_phone"/></a></p>
                    </t>
                </div>
                
                <div>
                    <a t-attf-href="mailto:{{vendor_email}}?subject=License Renewal Inquiry" class="btn btn-primary" style="padding: 10px 20px; margin-right: 10px;">Contact Support</a>
                    <a href="/web/login" class="btn btn-outline-secondary" style="padding: 10px 20px;">Return to Login</a>
                </div>
                
                <div class="footer-text">
                    Powered by <t t-out="vendor_name"/>
                </div>
            </div>
        </t>
    </template>
</odoo>
