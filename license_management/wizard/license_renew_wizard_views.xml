<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_license_renew_wizard_form" model="ir.ui.view">
        <field name="name">license.renew.wizard.form</field>
        <field name="model">license.renew.wizard</field>
        <field name="arch" type="xml">
            <form string="Renew License">
                <group>
                    <field name="renewal_key"/>
                    <field name="renewal_file" filename="renewal_file_name"/>
                </group>
                <footer>
                    <button name="action_renew" string="Renew" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_license_renew_wizard" model="ir.actions.act_window">
        <field name="name">Renew License</field>
        <field name="res_model">license.renew.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
