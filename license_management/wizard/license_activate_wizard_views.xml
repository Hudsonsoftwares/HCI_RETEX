<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_license_activate_wizard_form" model="ir.ui.view">
        <field name="name">license.activate.wizard.form</field>
        <field name="model">license.activate.wizard</field>
        <field name="arch" type="xml">
            <form string="Activate License">
                <group>
                    <field name="license_key"/>
                    <field name="license_file" filename="license_file_name"/>
                </group>
                <footer>
                    <button name="action_activate" string="Activate" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_license_activate_wizard" model="ir.actions.act_window">
        <field name="name">Activate License</field>
        <field name="res_model">license.activate.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
